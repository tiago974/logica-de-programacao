programa {
  funcao inicio() 
  {
    real reais
    real dollares
    real cotacaoDollar

    escreva("Quantos reais serão convertidos? ")
    leia(reais)

    escreva("Qual a cotação atual do dollar? ")
    leia(cotacaoDollar)

    dollares = reais*cotacaoDollar

    escreva("Atualmente você tem: ", dollares, " dóllares")


  }
}
