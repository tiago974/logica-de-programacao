programa {
  funcao inicio() 
  {
     inteiro idade
     real altura
     logico alunoAtivo
     caracter sexo
     cadeia nomeCompleto


     idade = 20
     altura = 1.80
     alunoAtivo = verdadeiro
     sexo = 'M'
     nomeCompleto = "Tiago Henrique Ronchi da Silveira"


     escreva("Nome: ", nomeCompleto, "\n")
     escreva("Idade: ", idade, "\n")
     escreva("Altura: ", altura, "\n")
     escreva("Aluno ativo: ", alunoAtivo, "\n")
     escreva("Sexo: ", sexo)
  }
}

