programa {
  funcao inicio() 
  {
    cadeia nome
    escreva("Digite seu nome: ")
    leia(nome)

    inteiro numero, i
    escreva("Digite um número: ")
    leia(numero)

    para (i = 1; i <= numero; i++)
      {
        escreva(i, " - ", nome, "\n")
      }

     

    
      
       
      


  }
}
